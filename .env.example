# === Database (PostgreSQL) ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=music_store
# Connection url within Docker-network (host = db)
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@db:5432/music_store

# === Cache (Redis) ===
# URL for connection from within Docker-network (host = cache)
REDIS_URL=redis://cache:6379

# === Application Settings (FastAPI) ===
SECRET_KEY=secret_key_for_local_development_only
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Command to generate a key in the terminal:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
ENVIRONMENT=development

# JSON array. Leave empty when frontend and API use the same origin.
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

# === Authentication rate limiting ===
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=300

# Create the first admin explicitly with: uv run python seed.py
# Never commit real credentials.
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=replace-with-a-long-random-password

# === Music media ===
MUSIC_MEDIA_ROOT=uploads/music
MUSIC_MEDIA_BASE_URL=/api/v1/music
MUSIC_IMAGE_MAX_BYTES=10485760
MUSIC_AUDIO_MAX_BYTES=104857600
MUSIC_VIDEO_MAX_BYTES=524288000
MUSIC_UPLOAD_CHUNK_BYTES=1048576
FFPROBE_BIN=ffprobe
FFPROBE_TIMEOUT_SECONDS=15

# Set true behind the production Nginx config from deploy/nginx.music.conf.example.
MEDIA_USE_X_ACCEL_REDIRECT=false
MEDIA_X_ACCEL_PREFIX=/_protected_music_media
