# Place this inside the HTTPS server block. Adjust upstream and filesystem paths.

client_max_body_size 520m;

location /api/ {
    proxy_pass http://api:8000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Do not buffer large admin uploads on the Nginx disk first.
    proxy_request_buffering off;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
}

# The application returns X-Accel-Redirect to this location only after checking
# track/clip publication or admin authorization. It must never be public.
location /_protected_music_media/ {
    internal;
    alias /srv/amor-fati/music/;
    add_header Accept-Ranges bytes always;
    add_header X-Content-Type-Options nosniff always;
}
